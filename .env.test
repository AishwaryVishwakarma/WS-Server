# Integration test environment — matches docker-compose.test.yml.
# Contains only throwaway container credentials; safe to commit.
PORT=8001
SESSION_SECRET=test-session-secret
METRICS_TOKEN=test-metrics-token
REDIS_URL=redis://localhost:6381
SALT_ROUNDS=4
# Rate limiting off by default here — integration flows fire far more requests
# than any tier allows. The rate-limit suite overrides this before booting.
THROTTLE_DISABLED=true
DB_HOST=localhost
DB_PORT=3311
DB_USERNAME=root
DB_PASSWORD=test
DB_NAME=ws_test
