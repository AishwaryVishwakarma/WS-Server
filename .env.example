PORT=8000
SESSION_SECRET=<express-session-secret>
REDIS_URL=<redis-url>
SALT_ROUNDS=<bcrypt-salt-rounds>

DB_HOST=<db-host>
DB_USERNAME=<db-username>
DB_PASSWORD=<db-password>
DB_PORT=<db-port>
DB_NAME=<db-name>

# --- Dockerized dev infrastructure (npm run dev:infra:up) ---
# To develop against the docker-compose.dev.yml containers instead of
# natively installed MySQL/Redis, use these values:
# REDIS_URL=redis://localhost:6381
# DB_HOST=localhost
# DB_USERNAME=root
# DB_PASSWORD=dev
# DB_PORT=3308
# DB_NAME=ws_dev
