PORT=8000
SESSION_SECRET=dev-session-secret-change-me
SALT_ROUNDS=10

# Bearer token a Prometheus scraper must send to read GET /metrics. Optional
# locally (the endpoint stays closed without it); REQUIRED in production.
METRICS_TOKEN=dev-metrics-token-change-me

# Google OAuth client id for "Sign in with Google" (Google Cloud Console →
# Credentials → OAuth client → Web). Optional — unset disables the feature
# (POST /auth/google returns 503 and the web button hides). Set the SAME value
# as the web's NEXT_PUBLIC_GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_ID=

# Defaults match the dockerized dev infrastructure (npm run dev:infra:up).
# For a natively installed MySQL/Redis, change these accordingly
# (e.g. DB_PORT=3306, REDIS_URL=redis://localhost:6379).
REDIS_URL=redis://localhost:6380
DB_HOST=localhost
DB_USERNAME=root
DB_PASSWORD=dev
DB_PORT=3310
DB_NAME=ws_dev
